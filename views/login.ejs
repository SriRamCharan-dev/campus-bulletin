<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login · Campus Bulletin</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>
    <div class="container">
        <div class="auth-logo"><i class="fa-solid fa-graduation-cap"></i></div>
        <h1>Campus Bulletin</h1>
        <p class="auth-tagline">Welcome back — sign in to continue</p>

        <form action="/login" method="POST">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email">

            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Enter your password" required autocomplete="current-password">

            <button type="submit" class="wide"><i class="fa-solid fa-arrow-right-to-bracket"></i> Sign In</button>
        </form>

        <div class="auth-links">
            <p>Don't have an account? <a href="/signup" style="font-weight:700;">Create one</a></p>
            <div class="auth-divider">or</div>
            <p><a href="/users" style="color:var(--text-secondary); font-weight:600;"><i class="fa-solid fa-arrow-left"></i> Back to Home</a></p>
        </div>
    </div>
</body>

</html>
