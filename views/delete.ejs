<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Announcement · Campus Bulletin</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>
    <div class="container">
        <div class="delete-warning-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <h1>Delete Announcement</h1>
        <p class="page-subtitle">This action cannot be undone. Please confirm carefully.</p>

        <div class="delete-announce-title">
            "<%= announcement.title %>"
        </div>

        <div class="delete-form-wrap">
            <form method="POST" action="/delete/<%= announcement.id %>?_method=DELETE"
                style="padding:0; background:transparent; border:none; box-shadow:none; margin:0;">
                <button type="submit" class="danger" style="width:100%; padding:1rem;">
                    <i class="fa-solid fa-trash"></i> Yes, Delete Permanently
                </button>
            </form>
            <a href="/admin" class="cancel-link"><i class="fa-solid fa-xmark"></i> Cancel — keep it</a>
        </div>

        <div class="back-link">
            <a href="/admin"><i class="fa-solid fa-arrow-left"></i> Back to Admin Dashboard</a>
        </div>
    </div>
</body>

</html>
