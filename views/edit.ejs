<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Announcement · Campus Bulletin</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>
    <div class="container">
        <div class="page-icon"><i class="fa-solid fa-pen-to-square"></i></div>
        <h1>Edit Announcement</h1>
        <p class="page-subtitle">Update the fields below and save your changes.</p>

        <form method="POST" action="/edit/<%= announcement.id %>?_method=PATCH">

            <p class="meta-info" style="margin-bottom:1.5rem; font-size:0.82rem;">
                <i class="fa-solid fa-fingerprint"></i> Editing announcement <strong>#<%= announcement.id %></strong>
            </p>

            <label for="title">Title</label>
            <input type="text" id="title" name="title" placeholder="Announcement title"
                value="<%= announcement.title %>" required>

            <label for="content">Content</label>
            <textarea id="content" name="content" rows="8"><%= announcement.content %></textarea>

            <label for="category">Category</label>
            <input type="text" id="category" name="category" placeholder="Category"
                value="<%= announcement.category %>" required>

            <label for="event_date">Event Date</label>
            <input type="date" id="event_date" name="event_date"
                value="<%= announcement.event_date %>" required>

            <label for="venue">Venue</label>
            <input type="text" id="venue" name="venue" placeholder="Venue"
                value="<%= announcement.venue %>" required>

            <label for="roles">Posted By (Role)</label>
            <input type="text" id="roles" name="roles"
                value="<%= announcement.roles || '' %>" readonly>

            <div class="btn-group" style="justify-content:flex-start;">
                <button type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
            </div>

            <div class="danger-zone">
                <a href="/delete/<%= announcement.id %>"><i class="fa-solid fa-trash"></i> Delete this announcement</a>
            </div>

        </form>

        <div class="back-link">
            <a href="/admin"><i class="fa-solid fa-arrow-left"></i> Back to Admin Dashboard</a>
        </div>
    </div>
</body>

</html>
